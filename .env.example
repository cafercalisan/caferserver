# Veritabanı (Coolify PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/caferserver"

# Auth
AUTH_SECRET="openssl-rand-base64-32-ile-uretilmis-secret"
AUTH_URL="https://panel.cafercalisan.com"

# Coolify API
COOLIFY_API_URL="http://localhost:8000"
COOLIFY_API_TOKEN="coolify-api-token-buraya"

# SSH (panel ayni sunucuda oldugu icin localhost)
SSH_HOST="localhost"
SSH_PORT="22"
SSH_USERNAME="root"
SSH_PRIVATE_KEY="base64-encoded-private-key"
# veya SSH_PASSWORD="sifre"

# Health Check Cron Secret
HEALTH_CHECK_SECRET="rastgele-bir-secret"
